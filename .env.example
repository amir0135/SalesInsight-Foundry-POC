# =============================================================================
# SalesInsight Foundry POC - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# QUICKSTART (Snowflake + Azure OpenAI only):
#   1. Fill in the SNOWFLAKE and AZURE OPENAI sections below
#   2. Run: ./scripts/quickstart_snowflake.sh
#   Or see GETTING_STARTED.md for the full walkthrough.
#
# FULL SETUP (all features): Fill in every REQUIRED section.
# =============================================================================

# =============================================================================
# ❄️  SNOWFLAKE - Your sales data warehouse
# =============================================================================
# Get these from your Snowflake account (Admin > Accounts).
# See docs/snowflake_setup.md for table creation and data loading.

SNOWFLAKE_ACCOUNT=your-account.region           # e.g. xy12345.us-east-1
SNOWFLAKE_USER=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH                  # Your warehouse name
SNOWFLAKE_DATABASE=SALES_DB                      # Database with OrderHistoryLine
SNOWFLAKE_SCHEMA=ORDERS                          # Schema containing the table
SNOWFLAKE_ROLE=                                  # Optional: specific role

# Set to "true" to skip Snowflake and use local CSV files in data/ instead
SALESINSIGHT_USE_LOCAL_DATA=false

# =============================================================================
# 🤖 AZURE OPENAI - Required for natural language queries
# =============================================================================
# Get from Azure Portal > Azure OpenAI > Keys and Endpoint

AZURE_OPENAI_RESOURCE=your-openai-resource-name  # Resource name (not full URL)
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_MODEL_NAME=gpt-4o

# Authentication: "keys" (simpler) or "rbac" (recommended for production)
AZURE_AUTH_TYPE=keys

# =============================================================================
# 🔍 AZURE AI SEARCH - Required for document RAG (optional for SQL-only)
# =============================================================================
# Get from Azure Portal > AI Search > Keys
# You can skip this section if you only want NL2SQL (Snowflake queries).

AZURE_SEARCH_SERVICE=your-search-service-name
AZURE_SEARCH_KEY=your-search-key-here
AZURE_SEARCH_INDEX=your-index-name

# =============================================================================
# 📦 AZURE BLOB STORAGE - Required for document upload (optional for SQL-only)
# =============================================================================
# Get from Azure Portal > Storage Account > Access Keys

AZURE_BLOB_ACCOUNT_NAME=your-storage-account
AZURE_BLOB_ACCOUNT_KEY=your-storage-key
AZURE_BLOB_CONTAINER_NAME=documents

# =============================================================================
# 🟡 RECOMMENDED - Set these for full functionality
# =============================================================================

# Azure Form Recognizer / Document Intelligence (for PDF processing)
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-form-recognizer.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=your-key

# Chat History Storage (CosmosDB or PostgreSQL)
DATABASE_TYPE=CosmosDB
AZURE_COSMOSDB_ACCOUNT_NAME=your-cosmosdb-account
AZURE_COSMOSDB_DATABASE_NAME=chat-history
AZURE_COSMOSDB_CONVERSATIONS_CONTAINER_NAME=conversations

# =============================================================================
# 🟢 OPTIONAL - Defaults work for most cases
# =============================================================================

# OpenAI Model Configuration
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
AZURE_OPENAI_TEMPERATURE=0
AZURE_OPENAI_MAX_TOKENS=1000
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_STREAM=True

# Search Configuration
AZURE_SEARCH_TOP_K=5
AZURE_SEARCH_USE_SEMANTIC_SEARCH=False
AZURE_SEARCH_ENABLE_IN_DOMAIN=False

# Orchestration (openai_function, semantic_kernel, langchain, or prompt_flow)
ORCHESTRATION_STRATEGY=openai_function
CONVERSATION_FLOW=custom

# Logging
LOGLEVEL=INFO

# =============================================================================
# 🔵 ADVANCED - Only change if you know what you're doing
# =============================================================================

USE_KEY_VAULT=false
# AZURE_KEY_VAULT_ENDPOINT=https://your-keyvault.vault.azure.net/

# Backend URLs
BACKEND_URL=http://localhost:7071

# Search Field Mappings (usually auto-configured)
AZURE_SEARCH_FIELDS_ID=id
AZURE_SEARCH_CONTENT_COLUMN=content
AZURE_SEARCH_CONTENT_VECTOR_COLUMN=content_vector
AZURE_SEARCH_DIMENSIONS=1536
AZURE_SEARCH_FILENAME_COLUMN=filepath
AZURE_SEARCH_TITLE_COLUMN=title
AZURE_SEARCH_SOURCE_COLUMN=source

# Content Safety (optional filtering)
# AZURE_CONTENT_SAFETY_ENDPOINT=
# AZURE_CONTENT_SAFETY_KEY=

# Speech-to-Text (optional)
# AZURE_SPEECH_SERVICE_KEY=
# AZURE_SPEECH_SERVICE_REGION=

# Prompt Flow (only if using prompt_flow orchestration)
# AZURE_ML_WORKSPACE_NAME=
# PROMPT_FLOW_DEPLOYMENT_NAME=
# PROMPT_FLOW_ENDPOINT_NAME=

# =============================================================================
# 🗄️ DATABASE INTEGRATION (Optional - PostgreSQL)
# =============================================================================

# PostgreSQL database connection
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=database
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_SCHEMA=public
